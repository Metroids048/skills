model_provider = "custom"
model = "gpt-5.4"
model_reasoning_effort = "high"
disable_response_storage = true

[model_providers.custom]
name = "HCAI"
base_url = "http://127.0.0.1:15721/v1"
wire_api = "responses"
requires_openai_auth = true
experimental_bearer_token = "PROXY_MANAGED"

# Core MCP servers for coding / PM / vibe workflows.
# Secrets are not stored here. Set Windows user environment variables as needed:
# GITHUB_PERSONAL_ACCESS_TOKEN, EXA_API_KEY, FAL_KEY, FIGMA_API_KEY.
[mcp_servers.github]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-github"]
startup_timeout_sec = 30

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp@latest"]
startup_timeout_sec = 30

[mcp_servers.openaiDeveloperDocs]
url = "https://developers.openai.com/mcp"
startup_timeout_sec = 30

[mcp_servers.memory]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-memory"]
startup_timeout_sec = 30

[mcp_servers.sequential-thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]
startup_timeout_sec = 30

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@latest", "--browser", "chrome"]
startup_timeout_sec = 30

[mcp_servers.exa]
command = "npx"
args = ["-y", "mcp-remote", "https://mcp.exa.ai/mcp"]
startup_timeout_sec = 30

[mcp_servers.fal-ai]
command = "npx"
args = ["-y", "fal-ai-mcp-server"]
startup_timeout_sec = 30

[mcp_servers.filesystem-agent-platform]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "C:\\Users\\win\\Desktop\\program1-main"]
startup_timeout_sec = 30

[mcp_servers.chrome-devtools]
command = "npx"
args = ["-y", "chrome-devtools-mcp@latest"]
startup_timeout_sec = 30

[mcp_servers.node_repl]
args = []
command = 'C:\Users\win\AppData\Local\OpenAI\Codex\runtimes\cua_node\a89897d3d9baa117\bin\node_repl.exe'
startup_timeout_sec = 120

[mcp_servers.node_repl.env]
NODE_REPL_NATIVE_PIPE_CONNECT_TIMEOUT_MS = "1000"
NODE_REPL_NODE_MODULE_DIRS = 'C:\Users\win\AppData\Local\OpenAI\Codex\runtimes\cua_node\a89897d3d9baa117\bin\node_modules'
NODE_REPL_NODE_PATH = 'C:\Users\win\AppData\Local\OpenAI\Codex\runtimes\cua_node\a89897d3d9baa117\bin\node.exe'
NODE_REPL_TRUSTED_CODE_PATHS = 'C:\Users\win\.codex'
CODEX_HOME = 'C:\Users\win\.codex'
NODE_REPL_TRUSTED_BROWSER_CLIENT_SHA256S = "bdc61752e0f9d9b1e73e3cba25ca71d3d9fe54d335ed8196378106081474d7c1,eb55d24cf065cd5311af6f99b16bade2b7a670790ff2db9accf60d012dd55dd1"
BROWSER_USE_AVAILABLE_BACKENDS = "chrome,iab"
NODE_REPL_INSTRUCTIONS_USE_CASE_BROWSER = "Control the in-app browser in conjunction with the Browser Plugin."
NODE_REPL_INSTRUCTIONS_USE_CASE_CHROME = "Control the Chrome browser in conjunction with the Chrome Plugin. Prefer this method of controlling Chrome over alternatives (such as Computer Use) unless the user explicitly mentions an alternative."
BROWSER_USE_CODEX_APP_BUILD_FLAVOR = "prod"
BROWSER_USE_CODEX_APP_VERSION = "26.611.62324"
SKY_CUA_NATIVE_PIPE = "1"
SKY_CUA_NATIVE_PIPE_DIRECTORY = '\\.\pipe\codex-computer-use-b314f857-06c6-480f-9758-73cb0279fded'
CODEX_CLI_PATH = 'C:\Users\win\AppData\Local\OpenAI\Codex\bin\330bd0cba6496126\codex.exe'

[projects.'c:\users\win\desktop\program1-main']
trust_level = "trusted"
